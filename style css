/* ============================================================
   RESET & BASE
============================================================ */
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #FDF8F0;
    color: #2D1B0E;
    line-height: 1.6;
}

h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    color: #2D1B0E;
}

a { text-decoration: none; color: inherit; }

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
}

/* ============================================================
   HEADER
============================================================ */
.header {
    background: #2D1B0E;
    padding: 0.8rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 20px rgba(0,0,0,0.15);
}

.header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: #FDF8F0;
    font-family: 'Playfair Display', serif;
}

.logo-img {
    height: 40px;
    width: auto;
}

.logo-accent { color: #D4A853; }

.nav {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
}

.nav-link {
    color: #B8A89A;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: 0.2s;
}

.nav-link:hover { color: #FDF8F0; }
.nav-link.active { color: #FDF8F0; background: #4A3728; }
.nav-link.export-link { color: #D4A853; font-weight: 700; }
.nav-link.contact-link { color: #0A7E8C; }
.nav-link.admin-link { color: #D4A853; font-weight: 700; }

.header-actions .btn-small {
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
}

/* ============================================================
   BUTTONS
============================================================ */
.btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
}

.btn-primary {
    background: #D4A853;
    color: #2D1B0E;
    box-shadow: 0 4px 12px rgba(212, 168, 83, 0.3);
}

.btn-primary:hover {
    background: #C49A42;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 168, 83, 0.4);
}

.pulse-btn {
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.7); }
    70% { box-shadow: 0 0 0 10px rgba(212, 168, 83, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 168, 83, 0); }
}

.btn-outline {
    background: transparent;
    color: #FDF8F0;
    border: 2px solid #FDF8F0;
}

.btn-outline:hover {
    background: #FDF8F0;
    color: #2D1B0E;
}

.btn-large { padding: 0.8rem 2.5rem; font-size: 1.1rem; }
.btn-small { padding: 0.4rem 1.2rem; font-size: 0.85rem; }

/* ============================================================
   MARQUEE
============================================================ */
.marquee-wrapper {
    background: #D4A853;
    color: #2D1B0E;
    padding: 0.4rem 0;
    overflow: hidden;
    border-bottom: 2px solid #2D1B0E;
}

.marquee {
    white-space: nowrap;
    animation: scrollText 20s linear infinite;
    font-weight: 600;
    font-size: 0.9rem;
}

@keyframes scrollText {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
}

/* ============================================================
   HERO
============================================================ */
.hero {
    background: linear-gradient(135deg, #2D1B0E 0%, #4A3728 100%);
    color: #FDF8F0;
    padding: 4rem 1.5rem;
}

.hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
}

.hero-content { display: flex; flex-direction: column; gap: 1.5rem; }

.hero-badge {
    display: inline-block;
    background: rgba(212, 168, 83, 0.2);
    color: #D4A853;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    width: fit-content;
}

.hero-content h1 {
    font-size: 3.2rem;
    line-height: 1.2;
    color: #FDF8F0;
}

.hero-content h1 .highlight { color: #D4A853; }

.hero-sub {
    font-size: 1.2rem;
    color: #B8A89A;
    max-width: 500px;
}

.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.hero-stats { display: flex; gap: 2rem; margin-top: 0.5rem; }
.hero-stats .stat { font-size: 0.95rem; color: #B8A89A; }
.hero-stats .stat strong { color: #FDF8F0; font-size: 1.2rem; }

/* ============================================================
   BORDERLESS MOCKUP
============================================================ */
.hero-mockup.borderless {
    display: flex;
    align-items: flex-end;
    gap: 0;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.4));
    justify-content: center;
}

.hero-mockup.borderless .book-spine {
    width: 20px;
    height: 280px;
    background: #3D2A1A;
    border-radius: 2px 0 0 2px;
}

.hero-mockup.borderless .book-cover {
    width: 200px;
    height: 280px;
    background: #D4A853;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    text-align: center;
    color: #2D1B0E;
    position: relative;
    border-radius: 0 4px 4px 0;
}

.hero-mockup.borderless .book-cover .book-brand { font-size: 2rem; margin-bottom: 0.3rem; }
.hero-mockup.borderless .book-cover h3 { font-size: 1.4rem; margin-bottom: 0.2rem; }
.hero-mockup.borderless .book-cover p { font-size: 0.9rem; color: #4A3728; }
.hero-mockup.borderless .book-cover .book-decoration {
    position: absolute;
    bottom: 1.5rem;
    width: 60%;
    height: 2px;
    background: rgba(26, 42, 58, 0.3);
}

/* ============================================================
   CAROUSEL
============================================================ */
.carousel-section {
    padding: 4rem 1.5rem;
    background: #FDF8F0;
}

.carousel-container {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.carousel-track {
    display: flex;
    transition: transform 0.5s ease-in-out;
}

.carousel-slide {
    min-width: 100%;
    position: relative;
}

.carousel-slide img {
    width: 100%;
    display: block;
    border-radius: 12px;
}

.carousel-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem;
    background: rgba(45, 27, 14, 0.8);
    color: #FDF8F0;
    text-align: center;
    font-weight: 500;
    border-radius: 0 0 12px 12px;
}

.carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(45, 27, 14, 0.6);
    color: #FDF8F0;
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    font-size: 1.5rem;
    cursor: pointer;
    transition: 0.3s;
    z-index: 10;
}

.carousel-btn:hover {
    background: #D4A853;
    color: #2D1B0E;
}

.carousel-btn-prev { left: 10px; }
.carousel-btn-next { right: 10px; }

.carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
}

.dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #C4B8A8;
    cursor: pointer;
    transition: 0.3s;
}

.dot.active {
    background: #D4A853;
    transform: scale(1.2);
}

.dot:hover { background: #D4A853; }

/* ============================================================
   COMPARISON TABLE
============================================================ */
.comparison {
    padding: 4rem 1.5rem;
    background: white;
}

.section-header { text-align: center; margin-bottom: 2.5rem; }
.section-header h2 { font-size: 2.4rem; margin-bottom: 0.5rem; }
.section-header p { color: #6A5A4A; font-size: 1.1rem; }

.comparison-table-wrapper {
    overflow-x: auto;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
}

.comparison-table th {
    background: #2D1B0E;
    color: #FDF8F0;
    padding: 1rem 1.2rem;
    text-align: left;
    font-weight: 600;
}

.comparison-table td {
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid #E8E0D8;
    color: #4A3728;
}

.comparison-table tr:hover td { background: #FDF8F0; }
.comparison-table .winner-row td { background: #FDF8F0; border-bottom: 2px solid #D4A853; }

.check { color: #0A7E8C; font-weight: 700; }
.cross { color: #E76F51; font-weight: 700; }
.one-time { font-size: 0.75rem; color: #8A7A6A; }
.winner-badge {
    display: inline-block;
    background: #D4A853;
    color: #2D1B0E;
    padding: 0.2rem 0.8rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.85rem;
}

.comparison-cta { text-align: center; margin-top: 2rem; }

/* ============================================================
   FEATURES
============================================================ */
.features { padding: 4rem 1.5rem; background: #FDF8F0; }

.feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

.feature-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
    border: 1px solid #E8E0D8;
    transition: 0.3s;
}

.feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    border-color: #D4A853;
}

.feature-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
.feature-card h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
.feature-card p { font-size: 0.9rem; color: #6A5A4A; line-height: 1.6; }

/* ============================================================
   TESTIMONIAL
============================================================ */
.testimonial {
    padding: 3rem 1.5rem;
    background: #2D1B0E;
    color: #FDF8F0;
    text-align: center;
}

.testimonial-content blockquote {
    font-size: 1.4rem;
    font-style: italic;
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto 1rem;
    font-family: 'Playfair Display', serif;
}

.testimonial-content cite {
    color: #B8A89A;
    font-style: normal;
    font-size: 0.95rem;
}

/* ============================================================
   FOOTER
============================================================ */
.footer {
    background: #2D1B0E;
    color: #B8A89A;
    padding: 3rem 1.5rem 1rem;
}

.footer-inner { max-width: 1200px; margin: 0 auto; }

.footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
}

.footer-col h4 {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: #FDF8F0;
    margin-bottom: 1rem;
}

.footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: #FDF8F0;
    font-family: 'Playfair Display', serif;
    margin-bottom: 0.5rem;
}

.footer-logo-img { height: 32px; width: auto; }
.footer-desc { font-size: 0.9rem; line-height: 1.6; max-width: 300px; }

.footer-links { list-style: none; }
.footer-links li { margin-bottom: 0.4rem; }
.footer-links a { font-size: 0.9rem; transition: 0.2s; }
.footer-links a:hover { color: #D4A853; }

.footer-social { display: flex; gap: 0.8rem; margin-top: 0.5rem; }
.social-link { font-size: 1.2rem; transition: 0.2s; }
.social-link:hover { color: #D4A853; }

.footer-bottom {
    border-top: 1px solid #4A3728;
    padding-top: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
}

.footer-disclaimer { color: #6A5A4A; margin-top: 0.3rem; }

/* ============================================================
   RESPONSIVE
============================================================ */
@media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; }
    .hero-mockup { justify-content: center; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
    .header-inner { flex-direction: column; align-items: center; }
    .nav { justify-content: center; }
    .hero-content h1 { font-size: 2.2rem; }
    .comparison-table { font-size: 0.8rem; }
    .footer-grid { grid-template-columns: 1fr; }
    .carousel-btn { width: 32px; height: 32px; font-size: 1rem; }
}

@media (max-width: 480px) {
    .hero-content h1 { font-size: 1.8rem; }
    .hero-stats { flex-direction: column; gap: 0.5rem; }
    .hero-mockup.borderless .book-cover { width: 160px; height: 220px; }
    .hero-mockup.borderless .book-spine { height: 220px; }
}
